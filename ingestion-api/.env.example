PORT=3001
NODE_ENV=development

# Storage
DATA_DIR=./data
LOTS_FILE=lots.json
STATE_FILE=sync-state.json

# Refresh scheduling (0 disables background loop)
REFRESH_INTERVAL_MINUTES=0
MAX_LOTS_PER_SOURCE=50
STALE_TO_UNAVAILABLE_HOURS=24
UNAVAILABLE_TO_ARCHIVED_HOURS=168

# Logging
LOG_LEVEL=info

# Extraction behavior
ENABLE_BROWSER_WARMUP=true
HUMAN_DELAY_MIN_MS=400
HUMAN_DELAY_MAX_MS=1200
REQUEST_TIMEOUT_MS=25000
MAX_RETRIES=3
RETRY_BASE_DELAY_MS=750

# Browser executable (set explicit path if autodetect fails)
CHROME_EXECUTABLE_PATH=

# Sources toggles
ENABLE_COPART=true
ENABLE_IAAI=true

# Optional manual seeds (comma-separated)
COPART_SEED_LOT_IDS=
IAAI_SEED_ITEM_IDS=

# Bootstrap from rebrowser dataset samples when live extraction fails
ALLOW_REFERENCE_FALLBACK=true
REFERENCE_MAX_ROWS=100
