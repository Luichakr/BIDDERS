{
  "name": "bidbiders-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && cp dist/index.html dist/404.html",
    "build:github": "VITE_DEPLOY_TARGET=github-pages npm run build",
    "build:cloudflare": "VITE_DEPLOY_TARGET=cloudflare npm run build",
    "lint": "eslint .",
    "preview": "vite preview",
    "i18n:sync": "node scripts/i18n/sync-overrides.mjs",
    "i18n:check-seo": "node scripts/i18n/check-seo-i18n.mjs",
    "i18n:find": "node scripts/i18n/find-hardcoded-text.mjs",
    "i18n:keys": "node scripts/i18n/check-missing-keys.mjs",
    "i18n:coverage": "node scripts/i18n/report-i18n-coverage.mjs",
    "i18n:audit": "node scripts/i18n/find-hardcoded-text.mjs; node scripts/i18n/check-missing-keys.mjs"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "puppeteer": "^24.42.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  }
}
